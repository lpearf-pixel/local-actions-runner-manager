#!/usr/bin/env bash
set -Eeuo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INSTANCES_DIR="${ROOT_DIR}/instances"
GLOBAL_ENV="${ROOT_DIR}/.env"
COMPOSE_FILE="${ROOT_DIR}/compose.yaml"

usage() {
  cat <<'EOF'
Usage:
  bash ./runnerctl create <name> <owner/repository>
  bash ./runnerctl start <name>
  bash ./runnerctl stop <name>
  bash ./runnerctl restart <name>
  bash ./runnerctl logs <name>
  bash ./runnerctl status [name]
  bash ./runnerctl list
  bash ./runnerctl start-all
  bash ./runnerctl stop-all
  bash ./runnerctl clean [name]
  bash ./runnerctl doctor <name>
  bash ./runnerctl remove <name>
  bash ./runnerctl setup
  bash ./runnerctl sync

Global secrets and proxy settings live in .env.
Per-project settings live in instances/<name>.env.
Use the Makefile commands when executable bits are unavailable, for example:
  make start NAME=chan-shuo
EOF
}

require_global_env() {
  if [[ ! -f "$GLOBAL_ENV" ]]; then
    echo "ERROR: missing ${GLOBAL_ENV}. Run: cp .env.example .env" >&2
    exit 1
  fi
  if ! grep -Eq '^GITHUB_TOKEN=.+$' "$GLOBAL_ENV"; then
    echo "ERROR: GITHUB_TOKEN must be set in ${GLOBAL_ENV}" >&2
    exit 1
  fi
}

instance_file() {
  printf '%s/%s.env' "$INSTANCES_DIR" "$1"
}

require_instance() {
  local file
  file="$(instance_file "$1")"
  if [[ ! -f "$file" ]]; then
    echo "ERROR: missing instance configuration: ${file}" >&2
    exit 1
  fi
}

env_value() {
  local file="$1"
  local key="$2"
  [[ -f "$file" ]] || return 0
  sed -n "s/^${key}=//p" "$file" | tail -n 1
}

instance_container_name() {
  local name="$1"
  local configured
  configured="$(env_value "$(instance_file "$name")" RUNNER_NAME)"
  if [[ -n "$configured" ]]; then
    printf '%s' "$configured"
  else
    printf 'home-%s-runner' "$name"
  fi
}

compose_instance() (
  set -Eeuo pipefail

  local name="$1"
  shift
  require_global_env
  require_instance "$name"

  local tmp_root temp_dir merged_env
  tmp_root="${TMPDIR:-/tmp}"
  tmp_root="${tmp_root%/}"
  temp_dir="$(mktemp -d "${tmp_root}/runner-${name}.XXXXXX")"
  merged_env="${temp_dir}/merged.env"

  cleanup_merged_env() {
    rm -rf -- "$temp_dir"
  }
  trap cleanup_merged_env EXIT HUP INT TERM

  umask 077
  cat "$GLOBAL_ENV" > "$merged_env"
  printf '\n' >> "$merged_env"
  cat "$(instance_file "$name")" >> "$merged_env"

  docker compose \
    --project-name "runner-${name}" \
    --env-file "$merged_env" \
    --file "$COMPOSE_FILE" \
    "$@"
)

list_names() {
  local file base
  mkdir -p "$INSTANCES_DIR"

  shopt -s nullglob
  {
    for file in "$INSTANCES_DIR"/*.env; do
      base="${file##*/}"
      [[ "$base" == "example.env" ]] && continue
      printf '%s\n' "${base%.env}"
    done
  } | sort
  shopt -u nullglob
}

create_instance() {
  local name="${1:?instance name required}"
  local repository="${2:?repository required in owner/repository format}"
  local file

  if [[ ! "$name" =~ ^[a-zA-Z0-9][a-zA-Z0-9_-]*$ ]]; then
    echo "ERROR: invalid instance name: ${name}" >&2
    exit 1
  fi
  if [[ ! "$repository" =~ ^[^/]+/[^/]+$ ]]; then
    echo "ERROR: repository must use owner/repository format" >&2
    exit 1
  fi

  mkdir -p "$INSTANCES_DIR"
  file="$(instance_file "$name")"
  if [[ -e "$file" ]]; then
    echo "ERROR: instance already exists: ${file}" >&2
    exit 1
  fi

  cat >"$file" <<EOF
GITHUB_REPOSITORY=${repository}
RUNNER_NAME=home-${name}-runner
RUNNER_LABELS=lan,docker,home,${name}
RUNNER_GROUP=Default
RUNNER_WORKDIR=_work
RUNNER_EPHEMERAL=false
EOF
  chmod 600 "$file"
  echo "Created ${file}"
}

status_all() {
  local found=false name
  printf '%-24s %-42s %s\n' INSTANCE REPOSITORY STATUS
  while IFS= read -r name; do
    found=true
    local repo status
    repo="$(env_value "$(instance_file "$name")" GITHUB_REPOSITORY)"
    status="$(compose_instance "$name" ps --format '{{.Status}}' 2>/dev/null | head -n1 || true)"
    [[ -n "$status" ]] || status="stopped"
    printf '%-24s %-42s %s\n' "$name" "$repo" "$status"
  done < <(list_names)
  if [[ "$found" == false ]]; then
    echo "No instances configured."
  fi
}

run_all() {
  local action="$1" name found=false
  while IFS= read -r name; do
    found=true
    echo "==> ${action}: ${name}"
    case "$action" in
      start) compose_instance "$name" up --detach --build ;;
      stop) compose_instance "$name" down ;;
    esac
  done < <(list_names)
  if [[ "$found" == false ]]; then
    echo "No instances configured."
  fi
}

clean_temp_files() {
  local tmp_root path removed=0
  tmp_root="${TMPDIR:-/tmp}"
  tmp_root="${tmp_root%/}"

  shopt -s nullglob
  for path in "${tmp_root}"/runner-*.env "${tmp_root}"/runner-*.??????; do
    [[ -e "$path" ]] || continue
    rm -rf -- "$path"
    echo "Removed temporary path: ${path}"
    removed=1
  done
  shopt -u nullglob

  if [[ "$removed" -eq 0 ]]; then
    echo "No stale runner temporary files found."
  fi
}

clean_command() {
  local name="${1:-}"
  clean_temp_files

  if [[ -n "$name" ]]; then
    require_instance "$name"
    echo "Removing containers and network for instance: ${name}"
    compose_instance "$name" down --remove-orphans || true
  fi
}

print_check() {
  local ok="$1"
  local message="$2"
  if [[ "$ok" == true ]]; then
    printf 'OK   %s\n' "$message"
  else
    printf 'FAIL %s\n' "$message"
  fi
}

doctor_instance() {
  local name="${1:?instance name required}"
  local container proxy configured_proxy
  local failed=false

  echo "Runner doctor: ${name}"

  if command -v docker >/dev/null 2>&1; then
    print_check true "Docker CLI is installed"
  else
    print_check false "Docker CLI is installed"
    return 1
  fi

  if docker info >/dev/null 2>&1; then
    print_check true "Docker daemon is reachable"
  else
    print_check false "Docker daemon is reachable"
    return 1
  fi

  if [[ -f "$GLOBAL_ENV" ]] && grep -Eq '^GITHUB_TOKEN=.+$' "$GLOBAL_ENV"; then
    print_check true "Global GITHUB_TOKEN is configured"
  else
    print_check false "Global GITHUB_TOKEN is configured"
    failed=true
  fi

  if [[ -f "$(instance_file "$name")" ]]; then
    print_check true "Instance configuration exists"
  else
    print_check false "Instance configuration exists"
    return 1
  fi

  configured_proxy="$(env_value "$GLOBAL_ENV" HTTPS_PROXY)"
  [[ -n "$configured_proxy" ]] || configured_proxy="$(env_value "$GLOBAL_ENV" HTTP_PROXY)"
  if [[ -n "$configured_proxy" ]]; then
    print_check true "Global proxy is configured"
  else
    print_check false "Global proxy is configured (optional when direct GitHub access is stable)"
  fi

  if compose_instance "$name" config >/dev/null 2>&1; then
    print_check true "Merged Compose configuration is valid"
  else
    print_check false "Merged Compose configuration is valid"
    failed=true
  fi

  container="$(instance_container_name "$name")"
  if docker inspect "$container" >/dev/null 2>&1; then
    print_check true "Container exists: ${container}"
  else
    print_check false "Container exists: ${container}"
    return 1
  fi

  if [[ "$(docker inspect -f '{{.State.Running}}' "$container" 2>/dev/null || true)" == true ]]; then
    print_check true "Container is running"
  else
    print_check false "Container is running"
    return 1
  fi

  proxy="$(docker exec "$container" sh -lc 'printf "%s" "${HTTPS_PROXY:-${HTTP_PROXY:-}}"' 2>/dev/null || true)"
  if [[ -n "$proxy" ]]; then
    print_check true "Proxy reached the runner container"
  elif [[ -n "$configured_proxy" ]]; then
    print_check false "Proxy reached the runner container"
    failed=true
  else
    print_check true "Direct networking selected (no proxy configured)"
  fi

  if docker exec "$container" sh -lc 'pgrep -f Runner.Listener >/dev/null' >/dev/null 2>&1; then
    print_check true "Runner.Listener is active"
  else
    print_check false "Runner.Listener is active"
    failed=true
  fi

  if docker exec "$container" sh -lc 'curl -fsS --max-time 20 https://api.github.com/meta >/dev/null' >/dev/null 2>&1; then
    print_check true "GitHub API is reachable from the container"
  else
    print_check false "GitHub API is reachable from the container"
    failed=true
  fi

  [[ "$failed" == false ]]
}

setup_repository() {
  git -C "$ROOT_DIR" config core.fileMode false
  echo "Configured this checkout to ignore local executable-bit noise."
  echo "Use Makefile commands such as: make start NAME=chan-shuo"
}

sync_repository() {
  git -C "$ROOT_DIR" config core.fileMode false
  echo "Pulling repository updates with fast-forward-only mode..."
  git -C "$ROOT_DIR" pull --ff-only
}

command="${1:-help}"
shift || true

case "$command" in
  create) create_instance "$@" ;;
  start)
    name="${1:?instance name required}"
    compose_instance "$name" up --detach --build
    compose_instance "$name" ps
    ;;
  stop)
    name="${1:?instance name required}"
    compose_instance "$name" down
    ;;
  restart)
    name="${1:?instance name required}"
    compose_instance "$name" down
    compose_instance "$name" up --detach --build
    ;;
  logs)
    name="${1:?instance name required}"
    compose_instance "$name" logs --follow --tail=100
    ;;
  status)
    if [[ $# -gt 0 ]]; then
      compose_instance "$1" ps
    else
      status_all
    fi
    ;;
  list) status_all ;;
  start-all) run_all start ;;
  stop-all) run_all stop ;;
  clean) clean_command "${1:-}" ;;
  doctor) doctor_instance "${1:?instance name required}" ;;
  setup) setup_repository ;;
  sync) sync_repository ;;
  remove)
    name="${1:?instance name required}"
    compose_instance "$name" down --volumes
    rm -f "$(instance_file "$name")"
    echo "Removed instance: ${name}"
    ;;
  help|-h|--help) usage ;;
  *)
    echo "ERROR: unknown command: ${command}" >&2
    usage >&2
    exit 1
    ;;
esac

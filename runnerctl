#!/usr/bin/env bash
set -Eeuo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INSTANCES_DIR="${ROOT_DIR}/instances"
GLOBAL_ENV="${ROOT_DIR}/.env"
COMPOSE_FILE="${ROOT_DIR}/compose.yaml"

usage() {
  cat <<'EOF'
Usage:
  bash ./runnerctl create <name> <owner/repository>
  bash ./runnerctl add-worker <base> <worker-id> [--start] [--join-pool]
  bash ./runnerctl scale <base> <count> [--start] [--join-pool]
  bash ./runnerctl downscale <base> <count> [--stop-only|--remove-config] [--force]
  bash ./runnerctl workers <base>
  bash ./runnerctl pool-join <instance> <shared-label>
  bash ./runnerctl pool-leave <instance> <shared-label>
  bash ./runnerctl start <name>
  bash ./runnerctl stop <name>
  bash ./runnerctl restart <name>
  bash ./runnerctl logs <name>
  bash ./runnerctl status [name]
  bash ./runnerctl list
  bash ./runnerctl compose <name> <docker-compose-args...>
  bash ./runnerctl start-all
  bash ./runnerctl stop-all
  bash ./runnerctl clean [name]
  bash ./runnerctl doctor-host
  bash ./runnerctl doctor <name>
  bash ./runnerctl repair-permissions
  bash ./runnerctl remove <name>
  bash ./runnerctl setup
  bash ./runnerctl sync

Global secrets and proxy settings live in .env.
Per-project settings live in instances/<name>.env.
Invoke through bash so executable file permissions are not required.

Scaling defaults are conservative: workers are isolated unless --join-pool is passed.
EOF
}

require_global_env() {
  if [[ ! -f "$GLOBAL_ENV" ]]; then
    echo "ERROR: missing ${GLOBAL_ENV}. Run: cp .env.example .env" >&2
    exit 1
  fi
  if [[ ! -r "$GLOBAL_ENV" ]]; then
    echo "ERROR: ${GLOBAL_ENV} is not readable. Run: bash ./runnerctl repair-permissions" >&2
    exit 1
  fi
  if ! grep -Eq '^GITHUB_TOKEN=.+$' "$GLOBAL_ENV"; then
    echo "ERROR: GITHUB_TOKEN must be set in ${GLOBAL_ENV}" >&2
    exit 1
  fi
}

instance_file() {
  printf '%s/%s.env' "$INSTANCES_DIR" "$1"
}

require_instance() {
  local file
  file="$(instance_file "$1")"
  if [[ ! -f "$file" ]]; then
    echo "ERROR: missing instance configuration: ${file}" >&2
    exit 1
  fi
  if [[ ! -r "$file" ]]; then
    echo "ERROR: instance configuration is not readable: ${file}" >&2
    echo "Run: bash ./runnerctl repair-permissions" >&2
    exit 1
  fi
}

validate_instance_name() {
  local name="$1"
  if [[ ! "$name" =~ ^[a-zA-Z0-9][a-zA-Z0-9_-]*$ ]]; then
    echo "ERROR: invalid instance name: ${name}" >&2
    exit 1
  fi
}

validate_positive_count() {
  local count="$1"
  if [[ ! "$count" =~ ^[0-9]+$ || "$count" -lt 1 ]]; then
    echo "ERROR: count must be an integer greater than or equal to 1" >&2
    exit 1
  fi
}

env_value() {
  local file="$1"
  local key="$2"
  [[ -f "$file" && -r "$file" ]] || return 0
  sed -n "s/^${key}=//p" "$file" | tail -n 1
}

set_env_value() {
  local file="$1" key="$2" value="$3" tmp
  tmp="$(mktemp "${TMPDIR:-/tmp}/runner-env.XXXXXX")"
  awk -v key="$key" -v value="$value" '
    BEGIN { done = 0 }
    $0 ~ "^" key "=" { print key "=" value; done = 1; next }
    { print }
    END { if (!done) print key "=" value }
  ' "$file" > "$tmp"
  mv "$tmp" "$file"
  chmod 600 "$file"
}

label_contains() {
  local labels="$1" needle="$2" part
  IFS=',' read -r -a parts <<< "$labels"
  for part in "${parts[@]}"; do
    [[ "$part" == "$needle" ]] && return 0
  done
  return 1
}

append_label() {
  local labels="$1" label="$2"
  if [[ -z "$labels" ]]; then
    printf '%s' "$label"
  elif label_contains "$labels" "$label"; then
    printf '%s' "$labels"
  else
    printf '%s,%s' "$labels" "$label"
  fi
}

remove_label() {
  local labels="$1" label="$2" part out=""
  IFS=',' read -r -a parts <<< "$labels"
  for part in "${parts[@]}"; do
    [[ -z "$part" || "$part" == "$label" ]] && continue
    if [[ -z "$out" ]]; then
      out="$part"
    else
      out="${out},${part}"
    fi
  done
  printf '%s' "$out"
}

instance_container_name() {
  local name="$1"
  local configured
  configured="$(env_value "$(instance_file "$name")" RUNNER_NAME)"
  if [[ -n "$configured" ]]; then
    printf '%s' "$configured"
  else
    printf 'home-%s-runner' "$name"
  fi
}

container_status() {
  local container="$1"
  local state health

  if ! docker inspect "$container" >/dev/null 2>&1; then
    printf 'not-created'
    return 0
  fi

  state="$(docker inspect -f '{{.State.Status}}' "$container" 2>/dev/null || true)"
  [[ -n "$state" ]] || state="unknown"

  health="$(docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{end}}' "$container" 2>/dev/null || true)"
  if [[ -n "$health" ]]; then
    printf '%s (%s)' "$state" "$health"
  else
    printf '%s' "$state"
  fi
}

compose_instance() (
  set -Eeuo pipefail

  local name="$1"
  shift
  require_global_env
  require_instance "$name"

  local tmp_root temp_dir merged_env
  tmp_root="${TMPDIR:-/tmp}"
  tmp_root="${tmp_root%/}"
  temp_dir="$(mktemp -d "${tmp_root}/runner-${name}.XXXXXX")"
  merged_env="${temp_dir}/merged.env"

  cleanup_merged_env() {
    rm -rf -- "$temp_dir"
  }
  trap cleanup_merged_env EXIT HUP INT TERM

  umask 077
  cat "$GLOBAL_ENV" > "$merged_env"
  printf '\n' >> "$merged_env"
  cat "$(instance_file "$name")" >> "$merged_env"

  docker compose \
    --project-name "runner-${name}" \
    --env-file "$merged_env" \
    --file "$COMPOSE_FILE" \
    "$@"
)

list_names() {
  local file base
  mkdir -p "$INSTANCES_DIR"

  shopt -s nullglob
  {
    for file in "$INSTANCES_DIR"/*.env; do
      base="${file##*/}"
      [[ "$base" == "example.env" ]] && continue
      printf '%s\n' "${base%.env}"
    done
  } | sort
  shopt -u nullglob
}

create_instance() {
  local name="${1:?instance name required}"
  local repository="${2:?repository required in owner/repository format}"
  local file

  validate_instance_name "$name"
  if [[ ! "$repository" =~ ^[^/]+/[^/]+$ ]]; then
    echo "ERROR: repository must use owner/repository format" >&2
    exit 1
  fi

  mkdir -p "$INSTANCES_DIR"
  chmod 700 "$INSTANCES_DIR" 2>/dev/null || true
  file="$(instance_file "$name")"
  if [[ -e "$file" ]]; then
    echo "ERROR: instance already exists: ${file}" >&2
    exit 1
  fi

  umask 077
  cat >"$file" <<EOF
GITHUB_REPOSITORY=${repository}
RUNNER_NAME=home-${name}-runner
RUNNER_LABELS=lan,docker,home,${name}
RUNNER_GROUP=Default
RUNNER_WORKDIR=_work
RUNNER_EPHEMERAL=false
EOF
  chmod 600 "$file"
  echo "Created ${file}"
}

create_worker_file() {
  local base="$1" worker_id="$2" join_pool="$3"
  local worker="${base}-${worker_id}" base_file worker_file repository group workdir ephemeral labels

  validate_instance_name "$base"
  validate_instance_name "$worker_id"
  require_instance "$base"

  worker_file="$(instance_file "$worker")"
  if [[ -e "$worker_file" ]]; then
    echo "ERROR: worker already exists: ${worker_file}" >&2
    exit 1
  fi

  base_file="$(instance_file "$base")"
  repository="$(env_value "$base_file" GITHUB_REPOSITORY)"
  [[ -n "$repository" ]] || { echo "ERROR: base instance missing GITHUB_REPOSITORY" >&2; exit 1; }
  group="$(env_value "$base_file" RUNNER_GROUP)"
  [[ -n "$group" ]] || group="Default"
  workdir="$(env_value "$base_file" RUNNER_WORKDIR)"
  [[ -n "$workdir" ]] || workdir="_work"
  ephemeral="$(env_value "$base_file" RUNNER_EPHEMERAL)"
  [[ -n "$ephemeral" ]] || ephemeral="false"

  if [[ "$join_pool" == true ]]; then
    labels="lan,docker,home,${base},${worker}"
  else
    labels="lan,docker,home,${worker}"
  fi

  mkdir -p "$INSTANCES_DIR"
  chmod 700 "$INSTANCES_DIR" 2>/dev/null || true
  umask 077
  cat >"$worker_file" <<EOF
GITHUB_REPOSITORY=${repository}
RUNNER_NAME=home-${worker}-runner
RUNNER_LABELS=${labels}
RUNNER_GROUP=${group}
RUNNER_WORKDIR=${workdir}
RUNNER_EPHEMERAL=${ephemeral}
EOF
  chmod 600 "$worker_file"
  echo "Created ${worker_file}"
}

add_worker_command() {
  local base="${1:?base instance name required}" worker_id="${2:?worker id required}"
  shift 2
  local start=false join_pool=false arg worker
  for arg in "$@"; do
    case "$arg" in
      --start) start=true ;;
      --join-pool) join_pool=true ;;
      *) echo "ERROR: unknown add-worker option: ${arg}" >&2; exit 1 ;;
    esac
  done
  create_worker_file "$base" "$worker_id" "$join_pool"
  worker="${base}-${worker_id}"
  if [[ "$start" == true ]]; then
    compose_instance "$worker" up --detach --build
    compose_instance "$worker" ps
  fi
}

pool_label_command() {
  local mode="$1" name="${2:?instance name required}" label="${3:?shared label required}"
  local file labels updated
  validate_instance_name "$label"
  require_instance "$name"
  file="$(instance_file "$name")"
  labels="$(env_value "$file" RUNNER_LABELS)"
  [[ -n "$labels" ]] || labels="lan,docker,home,${name}"
  if [[ "$mode" == join ]]; then
    updated="$(append_label "$labels" "$label")"
  else
    updated="$(remove_label "$labels" "$label")"
  fi
  set_env_value "$file" RUNNER_LABELS "$updated"
  echo "Updated labels for ${name}: ${updated}"
}

worker_sort_key() {
  local name="$1"
  if [[ "$name" =~ -w([0-9]+)$ ]]; then
    printf '%08d %s\n' "${BASH_REMATCH[1]}" "$name"
  fi
}

list_workers_for_base() {
  local base="$1" name
  while IFS= read -r name; do
    if [[ "$name" =~ ^${base}-w[0-9]+$ ]]; then
      worker_sort_key "$name"
    fi
  done < <(list_names) | sort -n | awk '{print $2}'
}

workers_command() {
  local base="${1:?base instance name required}" worker
  require_instance "$base"
  printf '%s\n' "$base"
  while IFS= read -r worker; do
    [[ -n "$worker" ]] && printf '%s\n' "$worker"
  done < <(list_workers_for_base "$base")
}

scale_command() {
  local base="${1:?base instance name required}" count="${2:?count required}"
  shift 2
  local start=false join_pool=false arg i worker_id worker
  validate_positive_count "$count"
  require_instance "$base"
  for arg in "$@"; do
    case "$arg" in
      --start) start=true ;;
      --join-pool) join_pool=true ;;
      *) echo "ERROR: unknown scale option: ${arg}" >&2; exit 1 ;;
    esac
  done
  for ((i = 1; i < count; i += 1)); do
    printf -v worker_id 'w%02d' "$i"
    worker="${base}-${worker_id}"
    if [[ -e "$(instance_file "$worker")" ]]; then
      echo "Worker already exists: ${worker}"
      continue
    fi
    create_worker_file "$base" "$worker_id" "$join_pool"
    if [[ "$start" == true ]]; then
      compose_instance "$worker" up --detach --build
      compose_instance "$worker" ps
    fi
  done
}

downscale_command() {
  local base="${1:?base instance name required}" count="${2:?count required}"
  shift 2
  local mode="stop-only" force=false arg keep worker total index running
  validate_positive_count "$count"
  require_instance "$base"
  for arg in "$@"; do
    case "$arg" in
      --stop-only) mode="stop-only" ;;
      --remove-config) mode="remove-config" ;;
      --force) force=true ;;
      *) echo "ERROR: unknown downscale option: ${arg}" >&2; exit 1 ;;
    esac
  done

  mapfile -t workers < <(list_workers_for_base "$base")
  total="${#workers[@]}"
  keep=$((count - 1))
  (( keep < 0 )) && keep=0
  if (( total <= keep )); then
    echo "No workers selected for downscale."
    return 0
  fi

  for ((index = total - 1; index >= keep; index -= 1)); do
    worker="${workers[$index]}"
    running="$(docker inspect -f '{{.State.Running}}' "$(instance_container_name "$worker")" 2>/dev/null || echo false)"
    if [[ "$mode" == "remove-config" && "$running" == true && "$force" != true ]]; then
      echo "ERROR: refusing to remove running worker without --force: ${worker}" >&2
      exit 1
    fi
    echo "Stopping worker: ${worker}"
    compose_instance "$worker" down
    if [[ "$mode" == "remove-config" ]]; then
      rm -f "$(instance_file "$worker")"
      echo "Removed worker configuration: ${worker}"
    fi
  done
}

status_all() {
  local found=false name file repo container status runner_name labels
  printf '%-24s %-42s %-28s %-38s %s\n' INSTANCE REPOSITORY RUNNER_NAME LABELS STATUS
  while IFS= read -r name; do
    found=true
    file="$(instance_file "$name")"
    container="home-${name}-runner"

    if [[ ! -r "$file" ]]; then
      repo="permission-denied"
      runner_name="permission-denied"
      labels="permission-denied"
      status="$(container_status "$container")"
    else
      repo="$(env_value "$file" GITHUB_REPOSITORY)"
      [[ -n "$repo" ]] || repo="unknown"
      runner_name="$(env_value "$file" RUNNER_NAME)"
      [[ -n "$runner_name" ]] || runner_name="home-${name}-runner"
      labels="$(env_value "$file" RUNNER_LABELS)"
      [[ -n "$labels" ]] || labels="unknown"
      container="$runner_name"
      status="$(container_status "$container")"
    fi

    printf '%-24s %-42s %-28s %-38s %s\n' "$name" "$repo" "$runner_name" "$labels" "$status"
  done < <(list_names)
  if [[ "$found" == false ]]; then
    echo "No instances configured."
  fi
}

status_one() {
  local name="${1:?instance name required}"
  local file repo runner_name labels container status

  require_instance "$name"
  file="$(instance_file "$name")"
  repo="$(env_value "$file" GITHUB_REPOSITORY)"
  [[ -n "$repo" ]] || repo="unknown"
  runner_name="$(env_value "$file" RUNNER_NAME)"
  [[ -n "$runner_name" ]] || runner_name="home-${name}-runner"
  labels="$(env_value "$file" RUNNER_LABELS)"
  [[ -n "$labels" ]] || labels="unknown"
  container="$runner_name"
  status="$(container_status "$container")"

  printf '%-24s %-42s %-28s %-38s %s\n' INSTANCE REPOSITORY RUNNER_NAME LABELS STATUS
  printf '%-24s %-42s %-28s %-38s %s\n' "$name" "$repo" "$runner_name" "$labels" "$status"
}

run_all() {
  local action="$1" name found=false
  while IFS= read -r name; do
    found=true
    echo "==> ${action}: ${name}"
    case "$action" in
      start) compose_instance "$name" up --detach --build ;;
      stop) compose_instance "$name" down ;;
    esac
  done < <(list_names)
  if [[ "$found" == false ]]; then
    echo "No instances configured."
  fi
}

clean_temp_files() {
  local tmp_root path removed=0
  tmp_root="${TMPDIR:-/tmp}"
  tmp_root="${tmp_root%/}"

  shopt -s nullglob
  for path in "${tmp_root}"/runner-*.env "${tmp_root}"/runner-*.??????; do
    [[ -e "$path" ]] || continue
    rm -rf -- "$path"
    echo "Removed temporary path: ${path}"
    removed=1
  done
  shopt -u nullglob

  if [[ "$removed" -eq 0 ]]; then
    echo "No stale runner temporary files found."
  fi
}

clean_command() {
  local name="${1:-}"
  clean_temp_files

  if [[ -n "$name" ]]; then
    require_instance "$name"
    echo "Removing containers and network for instance: ${name}"
    compose_instance "$name" down --remove-orphans || true
  fi
}

print_check() {
  local ok="$1"
  local message="$2"
  if [[ "$ok" == true ]]; then
    printf 'OK   %s\n' "$message"
  else
    printf 'FAIL %s\n' "$message"
  fi
}

doctor_host() {
  local failed=false context socket_path client_version server_version memory cpus

  echo "Runner host doctor"

  if command -v docker >/dev/null 2>&1; then
    print_check true "Docker CLI is installed"
  else
    print_check false "Docker CLI is installed"
    return 1
  fi

  context="$(docker context show 2>/dev/null || true)"
  if [[ -n "$context" ]]; then
    print_check true "Docker context: ${context}"
  else
    print_check false "Docker context is readable"
    failed=true
  fi

  if docker info >/dev/null 2>&1; then
    print_check true "Docker daemon is reachable"
  else
    print_check false "Docker daemon is reachable"
    failed=true
  fi

  client_version="$(docker version --format '{{.Client.Version}}' 2>/dev/null || true)"
  server_version="$(docker version --format '{{.Server.Version}}' 2>/dev/null || true)"
  if [[ -n "$client_version" ]]; then
    print_check true "Docker client version: ${client_version}"
  else
    print_check false "Docker client version is readable"
    failed=true
  fi
  if [[ -n "$server_version" ]]; then
    print_check true "Docker server version: ${server_version}"
  else
    print_check false "Docker server version is readable"
    failed=true
  fi

  socket_path=""
  if [[ -S /var/run/docker.sock || -L /var/run/docker.sock ]]; then
    socket_path="/var/run/docker.sock"
  elif [[ -S "$HOME/.docker/run/docker.sock" || -L "$HOME/.docker/run/docker.sock" ]]; then
    socket_path="$HOME/.docker/run/docker.sock"
  fi
  if [[ -n "$socket_path" ]]; then
    print_check true "Docker socket exists: ${socket_path}"
    ls -l "$socket_path" 2>/dev/null || true
  else
    print_check false "Docker socket exists at /var/run/docker.sock or HOME/.docker/run/docker.sock"
    failed=true
  fi

  cpus="$(docker info --format '{{.NCPU}}' 2>/dev/null || true)"
  memory="$(docker info --format '{{.MemTotal}}' 2>/dev/null || true)"
  if [[ -n "$cpus" ]]; then
    echo "INFO Docker CPUs: ${cpus}"
  fi
  if [[ -n "$memory" ]]; then
    echo "INFO Docker memory bytes: ${memory}"
  fi

  echo "INFO Use local runners only for trusted workflows that need local Docker, LAN services, private models, local data, or hardware."
  echo "INFO Keep ordinary lint/typecheck/unit jobs on GitHub-hosted runners when possible."

  [[ "$failed" == false ]]
}

doctor_instance() {
  local name="${1:?instance name required}"
  local container proxy configured_proxy
  local failed=false

  echo "Runner doctor: ${name}"

  if command -v docker >/dev/null 2>&1; then
    print_check true "Docker CLI is installed"
  else
    print_check false "Docker CLI is installed"
    return 1
  fi

  if docker info >/dev/null 2>&1; then
    print_check true "Docker daemon is reachable"
  else
    print_check false "Docker daemon is reachable"
    return 1
  fi

  if [[ -f "$GLOBAL_ENV" && -r "$GLOBAL_ENV" ]] && grep -Eq '^GITHUB_TOKEN=.+$' "$GLOBAL_ENV"; then
    print_check true "Global GITHUB_TOKEN is configured"
  else
    print_check false "Global GITHUB_TOKEN is configured and readable"
    failed=true
  fi

  if [[ -f "$(instance_file "$name")" && -r "$(instance_file "$name")" ]]; then
    print_check true "Instance configuration exists and is readable"
  else
    print_check false "Instance configuration exists and is readable"
    echo "Hint: bash ./runnerctl repair-permissions"
    return 1
  fi

  configured_proxy="$(env_value "$GLOBAL_ENV" HTTPS_PROXY)"
  [[ -n "$configured_proxy" ]] || configured_proxy="$(env_value "$GLOBAL_ENV" HTTP_PROXY)"
  if [[ -n "$configured_proxy" ]]; then
    print_check true "Global proxy is configured"
  else
    print_check false "Global proxy is configured (optional when direct GitHub access is stable)"
  fi

  if compose_instance "$name" config >/dev/null 2>&1; then
    print_check true "Merged Compose configuration is valid"
  else
    print_check false "Merged Compose configuration is valid"
    failed=true
  fi

  container="$(instance_container_name "$name")"
  if docker inspect "$container" >/dev/null 2>&1; then
    print_check true "Container exists: ${container}"
  else
    print_check false "Container exists: ${container}"
    return 1
  fi

  if [[ "$(docker inspect -f '{{.State.Running}}' "$container" 2>/dev/null || true)" == true ]]; then
    print_check true "Container is running"
  else
    print_check false "Container is running"
    return 1
  fi

  proxy="$(docker exec "$container" sh -lc 'printf "%s" "${HTTPS_PROXY:-${HTTP_PROXY:-}}"' 2>/dev/null || true)"
  if [[ -n "$proxy" ]]; then
    print_check true "Proxy reached the runner container"
  elif [[ -n "$configured_proxy" ]]; then
    print_check false "Proxy reached the runner container"
    failed=true
  else
    print_check true "Direct networking selected (no proxy configured)"
  fi

  if docker exec "$container" sh -lc 'pgrep -f Runner.Listener >/dev/null' >/dev/null 2>&1; then
    print_check true "Runner.Listener is active"
  else
    print_check false "Runner.Listener is active"
    failed=true
  fi

  if docker exec "$container" sh -lc 'curl -fsS --max-time 20 https://api.github.com/meta >/dev/null' >/dev/null 2>&1; then
    print_check true "GitHub API is reachable from the container"
  else
    print_check false "GitHub API is reachable from the container"
    failed=true
  fi

  [[ "$failed" == false ]]
}

repair_permissions() {
  local current_user current_group needs_sudo=false file
  current_user="$(id -un)"
  current_group="$(id -gn)"

  mkdir -p "$INSTANCES_DIR" 2>/dev/null || true

  if [[ -e "$GLOBAL_ENV" && ! -O "$GLOBAL_ENV" ]]; then
    needs_sudo=true
  fi
  if [[ -e "$INSTANCES_DIR" && ! -O "$INSTANCES_DIR" ]]; then
    needs_sudo=true
  fi

  shopt -s nullglob
  for file in "$INSTANCES_DIR"/*.env; do
    if [[ ! -O "$file" ]]; then
      needs_sudo=true
      break
    fi
  done
  shopt -u nullglob

  if [[ "$needs_sudo" == true ]]; then
    if ! command -v sudo >/dev/null 2>&1; then
      echo "ERROR: sudo is required to repair root-owned instance files" >&2
      return 1
    fi
    echo "Repairing ownership for runner configuration files..."
    sudo chown "$current_user:$current_group" "$INSTANCES_DIR"
    sudo chown -R "$current_user:$current_group" "$INSTANCES_DIR"
    if [[ -e "$GLOBAL_ENV" ]]; then
      sudo chown "$current_user:$current_group" "$GLOBAL_ENV"
    fi
  fi

  chmod 700 "$INSTANCES_DIR"
  shopt -s nullglob
  for file in "$INSTANCES_DIR"/*.env; do
    chmod 600 "$file"
  done
  shopt -u nullglob
  if [[ -e "$GLOBAL_ENV" ]]; then
    chmod 600 "$GLOBAL_ENV"
  fi

  echo "Runner configuration permissions repaired."
  ls -ld "$INSTANCES_DIR"
  shopt -s nullglob
  for file in "$INSTANCES_DIR"/*.env; do
    ls -l "$file"
  done
  shopt -u nullglob
}

setup_repository() {
  git -C "$ROOT_DIR" config core.fileMode false
  echo "Configured this checkout to ignore local executable-bit noise."
  echo "Use: bash ./runnerctl <command>"
}

sync_repository() {
  git -C "$ROOT_DIR" config core.fileMode false
  echo "Pulling repository updates with fast-forward-only mode..."
  git -C "$ROOT_DIR" pull --ff-only
}

command="${1:-help}"
shift || true

case "$command" in
  create) create_instance "$@" ;;
  add-worker) add_worker_command "$@" ;;
  scale) scale_command "$@" ;;
  downscale) downscale_command "$@" ;;
  workers) workers_command "${1:?base instance name required}" ;;
  pool-join) pool_label_command join "$@" ;;
  pool-leave) pool_label_command leave "$@" ;;
  start)
    name="${1:?instance name required}"
    compose_instance "$name" up --detach --build
    compose_instance "$name" ps
    ;;
  stop)
    name="${1:?instance name required}"
    compose_instance "$name" down
    ;;
  restart)
    name="${1:?instance name required}"
    compose_instance "$name" down
    compose_instance "$name" up --detach --build
    ;;
  logs)
    name="${1:?instance name required}"
    compose_instance "$name" logs --follow --tail=100
    ;;
  status)
    if [[ $# -gt 0 ]]; then
      status_one "$1"
    else
      status_all
    fi
    ;;
  list) status_all ;;
  compose)
    name="${1:?instance name required}"
    shift
    [[ $# -gt 0 ]] || { echo "ERROR: docker compose arguments are required" >&2; exit 1; }
    compose_instance "$name" "$@"
    ;;
  start-all) run_all start ;;
  stop-all) run_all stop ;;
  clean) clean_command "${1:-}" ;;
  doctor-host) doctor_host ;;
  doctor) doctor_instance "${1:?instance name required}" ;;
  repair-permissions) repair_permissions ;;
  setup) setup_repository ;;
  sync) sync_repository ;;
  remove)
    name="${1:?instance name required}"
    compose_instance "$name" down --volumes
    rm -f "$(instance_file "$name")"
    echo "Removed instance: ${name}"
    ;;
  help|-h|--help) usage ;;
  *)
    echo "ERROR: unknown command: ${command}" >&2
    usage >&2
    exit 1
    ;;
esac

# Shared GitHub token used to register repository-level runners.
# Fine-grained PAT: grant each target repository Administration read/write.
GITHUB_TOKEN=github_pat_replace_me

# Shared network proxy for image builds and runner jobs.
HTTP_PROXY=http://192.168.2.28:8001
HTTPS_PROXY=http://192.168.2.28:8001

# Shared defaults. An instance file may override these values.
RUNNER_GROUP=Default
RUNNER_WORKDIR=_work
RUNNER_EPHEMERAL=false
RUNNER_LABELS=lan,docker,home

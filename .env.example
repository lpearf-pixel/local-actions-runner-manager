# Repository that will use this runner, without https://github.com/
GITHUB_REPOSITORY=lpearf-pixel/example-repository

# Fine-grained PAT with repository Administration: read/write, or classic PAT.
GITHUB_TOKEN=github_pat_replace_me

RUNNER_NAME=home-runner-01
RUNNER_LABELS=lan,docker,home
RUNNER_GROUP=Default
RUNNER_WORKDIR=_work
RUNNER_EPHEMERAL=false
